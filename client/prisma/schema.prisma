// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleStatus {
  ACTIVE
  TRANSFERRED
  FLAGGED
}

enum TransactionType {
  REGISTRATION
  TRANSFER
  VERIFICATION
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

model User {
  id            String    @id @default(cuid())
  walletAddress String?   @unique
  email         String?
  passwordHash  String?
  role          String    @default("owner")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  vehicles         Vehicle[]     @relation("VehicleOwner")
  sentTransactions Transaction[] @relation("TransactionFrom")
  receivedTransactions Transaction[] @relation("TransactionTo")

  @@map("users")
}

model Vehicle {
  id                 String        @id @default(cuid())
  vin                String        @unique
  make               String
  model              String
  year               Int
  color              String?
  ownerId            String
  registrationNumber String        @unique
  status             VehicleStatus @default(ACTIVE)
  txHash             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  owner        User          @relation("VehicleOwner", fields: [ownerId], references: [id])
  transactions Transaction[]

  @@map("vehicles")
}

model Transaction {
  id         String            @id @default(cuid())
  vehicleId  String
  fromUserId String
  toUserId   String
  txHash     String            @unique
  type       TransactionType
  status     TransactionStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  fromUser User    @relation("TransactionFrom", fields: [fromUserId], references: [id])
  toUser   User    @relation("TransactionTo", fields: [toUserId], references: [id])

  @@map("transactions")
}
